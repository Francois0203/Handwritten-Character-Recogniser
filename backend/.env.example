# Example environment variables for the Character Recognition API
# Copy this file to .env and customize as needed

# API Settings
APP_NAME="Character Recognition API"
DEBUG=false

# Server Settings
HOST=127.0.0.1
PORT=8000
RELOAD=false

# CORS Origins (comma-separated list for production)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Model Settings
MODEL_PATH=models/emnist_digits_standard_v1.keras
DATASET_NAME=emnist_digits

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10 MB in bytes
